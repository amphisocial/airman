; Airman — Godot 4 client.
; Open this folder with Godot 4 and export to Web.
; Keep Thread Support OFF in the export preset: single-threaded means the server
; doesn't need cross-origin isolation headers to serve the wasm.

config_version=5

[application]

config/name="Airman"
config/description="Two planes, one island, five hundred rounds."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"
boot_splash/show_image=false
boot_splash/bg_color=Color(0.184, 0.2, 0.153, 1)

[autoload]

Net="*res://autoload/Net.gd"
GameState="*res://autoload/GameState.gd"
Sfx="*res://autoload/Sfx.gd"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=0

